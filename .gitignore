# Automotive Diagnostic Skills - Git Ignore Rules

# Database files (SQLite)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Vehicle data files (large CSV/Excel files)
Vehicle data/
vehicle data zip files/
**/Vehicle data/
**/vehicle data zip files/

# Common failure data (source markdown)
Common Failure data/
**/Common Failure data/

# Backup files
*.backup
*.bak
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environment
venv/
env/
ENV/
env.bak/
venv.bak/

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Logs
*.log
logs/
*.log.*

# Temporary files
*.tmp
*.temp
temp/
tmp/

# Data files (raw import data — root-level only)
/data/
*.csv
*.tsv

# Test artifacts (keep test source files)
.pytest_cache/
.coverage
htmlcov/

# Documentation build files
docs/_build/
docs/.doctrees/

# Cache directories
.cache/
*.cache

# Environment variables (secrets)
# Note: .env.example is safe to commit (template only)
.env
.env.local
.env.*.local

# MCP Server configuration (safe to commit — uses ${ENV_VAR} references, no hardcoded keys)
# .mcp.json

# Compressed files
*.zip
*.tar.gz
*.rar

# Personal notes
notes.txt
TODO.txt
scratch.md
.venv/

# Frontend source lib/ — exempt from Python lib/ ignore pattern
!src/frontend/lib/
.env
/backups/

# Next.js build output (ephemeral, regenerated on build)
.next/
out/

# Root-level node_modules (frontend deps live in src/frontend/node_modules/)
/node_modules/

# Generated report subdirectories (NAS fallback — not source, not committed)
# Root-level reports/*.md and *.pdf are committed as examples; subdirs are not.
reports/Customer/
reports/Fleet/
reports/Pre-Purchase/
.harness/plans/*.json
