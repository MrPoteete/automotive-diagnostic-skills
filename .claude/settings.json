{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/poteete/.local/bin/uv run $CLAUDE_PROJECT_DIR/.claude/hooks/pre_tool_use.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/poteete/.local/bin/uv run $CLAUDE_PROJECT_DIR/.claude/hooks/delegation_check.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/poteete/.local/bin/uv run $CLAUDE_PROJECT_DIR/.claude/hooks/validators/precommit_validator.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/poteete/.local/bin/uv run $CLAUDE_PROJECT_DIR/.claude/hooks/validators/ruff_validator.py"
          },
          {
            "type": "command",
            "command": "/home/poteete/.local/bin/uv run $CLAUDE_PROJECT_DIR/.claude/hooks/validators/mypy_validator.py"
          },
          {
            "type": "command",
            "command": "/home/poteete/.local/bin/uv run $CLAUDE_PROJECT_DIR/.claude/hooks/validators/diagnostic_report_validator.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/poteete/.local/bin/uv run $CLAUDE_PROJECT_DIR/.claude/hooks/user_prompt_submit.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/poteete/.local/bin/uv run $CLAUDE_PROJECT_DIR/.claude/hooks/stop_hook.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/poteete/.local/bin/uv run $CLAUDE_PROJECT_DIR/.claude/hooks/status_line.py"
  }
}
