# Normalize line endings to LF on check-in (WSL/Linux native environment)
* text=auto eol=lf

# Binary files - no line ending conversion
*.db binary
*.db-shm binary
*.db-wal binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.gz binary

# Lock files - preserve as-is
package-lock.json -text
