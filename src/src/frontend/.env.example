# Automotive Diagnostic API Configuration
# Copy this file to .env.local and update with your settings

# ⚠️ SECURITY: API_KEY is server-side only (no NEXT_PUBLIC_ prefix)
# This key is NEVER exposed to the browser
# Must match the API_KEY in server/home_server.py
API_KEY=mechanic-secret-key-123

# Backend FastAPI server URL (for Next.js API routes to proxy to)
# This URL is NOT exposed to browser - only used server-side
BACKEND_URL=http://localhost:8000

# Backend URL for health checks (browser-side, no auth required)
# This is safe to expose - just the URL, no API key
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Production (Tailscale remote access) - uncomment and update:
# BACKEND_URL=http://100.x.x.x:8000
# NEXT_PUBLIC_BACKEND_URL=http://100.x.x.x:8000
