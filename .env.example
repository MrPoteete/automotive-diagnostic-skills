# Environment Variables Template
# Copy this to .env and fill in your actual values
# NEVER commit .env to git - it contains secrets!

# GitHub Authentication
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
GITHUB_USERNAME=your_github_username

# NHTSA API (usually no key required, but rate limits apply)
NHTSA_API_BASE_URL=https://api.nhtsa.gov

# OpenAI API (if using for embeddings/AI features)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Anthropic API (if using Claude API directly)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# Database Configuration
DATABASE_PATH=database/automotive_diagnostics.db
DATABASE_BACKUP_PATH=database/backups/

# Application Settings
LOG_LEVEL=INFO
ENABLE_DEBUG_MODE=false

# Context7 (if API key required)
CONTEXT7_API_KEY=your_context7_api_key_here

# RAG Server Configuration
RAG_SERVER_HOST=localhost
RAG_SERVER_PORT=5000
RAG_MODEL_PATH=models/diagnostic-model

# Security Settings
MAX_QUERY_LENGTH=2000
REQUIRE_SOURCE_ATTRIBUTION=true
SAFETY_CRITICAL_CONFIDENCE_THRESHOLD=0.9

# Firecrawl — local JS-rendered web scraping service
# Start the service: docker compose -f docker-compose.firecrawl.yml up -d
FIRECRAWL_API_URL=http://localhost:3002
